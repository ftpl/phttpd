use strict;
use warnings;
$SIG{PIPE} = 'IGNORE';
use Socket;
use IO::Select;
use Sys::Hostname;
use Encode;
use Encode::Guess;
use POSIX qw(strftime EAGAIN EWOULDBLOCK WNOHANG);
use Time::HiRes qw(time);
#use IO::Pipe;
#use Fcntl;
$|=1;

my $forceinet = defined $ENV{forceinet} ? $ENV{forceinet} : 0;
my $ipv6; eval {
    if ($forceinet) { die "=> User-specified IO::Socket::INET\n"; }
    require IO::Socket::IP;
    IO::Socket::IP->import();
    $ipv6 = 1;
};
if ($@) {
    warn "Failed to load IO::Socket::IP: $@";
    # for perl-5.8(not support ipv6)
    require IO::Socket::INET;
    IO::Socket::INET->import();
    $ipv6 = 0;
}

my $timestamp = 'view'; # time();
my $host = hostname;
my $ver = rt(__FILE__, 2); $ver =~ s/^#\s*/v/;
my $srv = "Pure-Static-HTTPd(flow)-$ver @ $host";
my $ipv6L = '['; my $ipv6R = ']'; 
my $addr = $ipv6 ? '::' : '0.0.0.0';
my $port = 58080;
# get响应每个连接占用内存缓冲区128k, 尚未完成的非阻塞模式:
my $bufSize = 128 * 1024;
# post上传时数据流切片长度，实际内存占用最多 2*$chunkSize:
# chunkSize在512KB~8MB范围内对HDD硬盘物理损耗和性能影响较小,
# 小内存如msys和androidTV处理大文件失败时可考虑512*1024
my $chunkSize = 4 * 1024 * 1024;
# 解析payload时切片长度应保证至少512字节,防止头部骑在下边界:
# 实际长度最多允许 2*$safeSize
my $safeSize = 512;
# 以上三个参数,非必要尽量不要修改
my $ismsys = ("$^O" eq "msys" || "$^O" eq "MSWin32") ? 1 : 0;
#
# 服务器根目录, '.'表示根目录为当前$PWD或%CD%文件夹
my $wwwroot = defined $ENV{wwwroot} ? $ENV{wwwroot} : '.'; $wwwroot =~ s/\/+$//;
# 上传请求的url, 客户端请求此url时返回一个htm上传页面
my $uploadurl = defined $ENV{uploadurl} ? $ENV{uploadurl} : "/ul"; $uploadurl =~ s/\/+$//;
# 上传文件夹系统路径, 若不是wwwroot子文件夹(如/tmp/ul)则上传后无法浏览
my $uploaddir = defined $ENV{uploaddir} ? $ENV{uploaddir} : $wwwroot . $uploadurl; $uploaddir =~ s/\/+$//;
#
# 是否自动索引文件列表(autoindex)
my $indexmode = defined $ENV{indexmode} ? $ENV{indexmode} : 1;
# 页面修复模式总开关, 决定是否修改内容后再输出
my $fixmode = defined $ENV{fixmode} ? $ENV{fixmode} : 1;
#
## log.control:
# 显示请求头/响应头(ph header)
my $dbgheader = defined $ENV{dbgheader} ? $ENV{dbgheader} : 1;
# 显示get响应的文本文件内容(pt js,css,html,text)
my $dbgtext = defined $ENV{dbgtext} ? $ENV{dbgtext} : 0;
# 显示get响应的二进制文件内容(pb binary-file)
my $dbgbinary = defined $ENV{dbgbinary} ? $ENV{dbgbinary} : 0;
# 显示post上传的请求体和解析出的文件内容(pp payload,content)
my $dbgpayload = defined $ENV{dbgpayload} ? $ENV{dbgpayload} : 0;

# 环境变量:
{
    print "usage: [fixmode=0 dbgheader=0] $0 [127.0.0.1:65535]\n";
    my @tracked_vars = qw(wwwroot uploaddir uploadurl forceinet indexmode fixmode dbgheader dbgtext dbgbinary dbgpayload ismsys);
    for my $var_name (@tracked_vars) { my $value = eval "\$$var_name"; if (defined $value) { print "  $var_name=$value\n"; } }
    print "perl-$^V\n";
}

# 使用第一个传入参数作为:
#  port
#  ipv4:port
#  [ipv6]:port
#  [ipv6]|ipv6|ipv4
#
if (@ARGV) {
    my $arg = $ARGV[0];
    if ($arg =~ /^(\d+)$/) {
    # 1. port
        if ($1 >= 1 && $1 <= 65535) { $port = $1; }
    } elsif ($arg =~ /^([0-9\.]+):(\d+)$/) {
    # 2. IPv4:port
        if ($2 >= 1 && $2 <= 65535) { $addr = $1; $port = $2; }
    } elsif ($arg =~ /^\[([0-9a-f\:]+)\]:(\d+)$/i) {
    # 3. [IPv6]:port
        if ($2 >= 1 && $2 <= 65535) { $addr = $1; $port = $2; }
    }
    elsif ($arg =~ /^\[([0-9a-f\:]+)\]$/i) { $addr = $1; }
    # 4. [IPv6]
    elsif ($arg =~ /^([0-9a-f\:]+)$/i) { $addr = $1; }
    # 5. IPv6
    elsif ($arg =~ /^([0-9\.]+)$/) { $addr = $1; }
    # 6. IPv4
}

if ($addr =~ /\./) { $ipv6L = ''; $ipv6R = ''; }

my %codes = (
'200', 'OK',
'201', 'Created',
'202', 'Accepted',
'204', 'No Content',
'207', 'Multi-Status',
'301', 'Moved Permanently',
'302', 'Moved Temporarily',
'304', 'Not Modified',
'400', 'Bad Request',
'401', 'Unauthorized',
'403', 'Forbidden',
'404', 'Not Found',
'413', 'Content Too Large',
'500', 'Internal Server Error',
'501', 'Not Implemented',
'502', 'Bad Gateway',
'503', 'Service Unavailable',
);

